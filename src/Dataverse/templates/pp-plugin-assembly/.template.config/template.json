{
  "$schema": "http://json.schemastore.org/template",
  "author": "NETWORG",
  "identity": "TALXIS.DevKit.Templates.Dataverse.Plugin.Assembly",
  "name": "Power Platform: Plugin Assembly",
  "shortName": "pp-plugin-assembly",
  "description": "Registers a plugin assembly in the solution. Script-only. Generates PluginAssemblies/{Name}-{GUID}/*.dll.data.xml. CHAIN: Step 2 \u2014 run in the target solution after pp-plugin. Required before pp-plugin-assembly-step.",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "symbols": {
    "AssemblyId": {
      "type": "parameter",
      "datatype": "text",
      "replaces": "__assembly-id__",
      "isRequired": true,
      "description": "Unique GUID identifier for the plugin assembly"
    },
    "PluginProjectRootPath": {
      "type": "parameter",
      "datatype": "text",
      "replaces": "__plugin-project-root__",
      "description": "Path to the plugin project root directory containing the compiled assembly"
    },
    "SolutionRootPath": {
			"type": "parameter",
			"datatype": "text",
			"defaultValue": ".",
			"replaces": "__solution-root-path__",
			"fileRename": "__solution-root-path__",
			"description": "Relative path from the project folder (.csproj) to the folder containing unpacked Dataverse solution files (Other/, Entities/, OptionSets/). Use '.' if solution files are directly in the project folder, or a subfolder name like 'Declarations'. Do not use 'Entities' or 'Other' — those are subdirectories inside the solution metadata root."
		}
  },
  "postActions": [
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/GenerateAssembly.ps1\" "
      },
      "description": "Generate assembly"
    },
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/AddAssemblyToSolution.ps1\" "
      },
      "description": "Add assembly to solution"
    },
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/AddPluginAssemblyCustomizationsXml.ps1\" "
      },
      "description": "Add plugin assembly customizations XML"
    },
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/Cleanup.ps1\"",
        "redirectStandardOutput": "false"
      },
      "manualInstructions": [
        {
          "text": "Removing template files"
        }
      ],
      "continueOnError": false,
      "description": "Removing template files"
    }
  ]
}