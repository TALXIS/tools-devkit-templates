{
  "$schema": "http://json.schemastore.org/template",
  "author": "NETWORG",
  "identity": "TALXIS.DevKit.Templates.Dataverse.Sitemap.Area",
  "name": "Power Platform: Site Map Area",
  "shortName": "pp-sitemap-area",
  "description": "Adds <Area> to app sitemap: Id, ResourceId, DescriptionResourceId, ShowGroups=true. Top-level navigation container. Add groups inside with pp-sitemap-group.",
  "classifications": ["Dataverse", "Power Platform"],
  "sourceName": "Sitemap-Area",
  "tags": {
		"language": "XML"
	},
  "preferNameDirectory": true,
  "symbols": {
    "SolutionRootPath": {
			"type": "parameter",
			"datatype": "text",
			"defaultValue": ".",
			"replaces": "SolutionDeclarationsRoot",
			"fileRename": "SolutionDeclarationsRoot",
			"description": "Folder under the project folder where solution components will be placed. Use the folder name only, not the full path. Use '.' if you want to place components directly in the project folder."
		},
    "AppName": {
      "type": "parameter",
      "datatype": "text",
      "description": "Name of the app module where the sitemap will be modified",
      "replaces": "appexamplename",
      "fileRename": "appexamplename"
    },
    "AreaTitle": {
      "type": "parameter",
      "datatype": "text",
      "description": "Title of the area that will be created in the sitemap",
      "defaultValue": "NewTitle",
      "replaces": "areatitleexample",
      "fileRename": "areatitleexample"
    }
  },
  "sources": [
    {
      "modifiers": [
        {
          "include": ["**/*.xml"]
        }
      ]
    }
  ],
  "postActions": [
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/GenerateIdForAppModuleSiteMap.ps1\" "
      },
      "manualInstructions": [
        {
          "text": "Adding Model Driven App to solution xml"
        }
      ]
    },
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/AddAreaToSitemap.ps1\""
      },
      "manualInstructions": [
        {
          "text": "Adding area to the sitemapp "
        }
      ]
    },
    {
			"actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
			"args": {
				"executable": "pwsh",
				"args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/Cleanup.ps1\"",
				"redirectStandardOutput": "false"
			},
			"manualInstructions": [{ "text": "Removing Scripts" }],
			"continueOnError": false,
			"description": "Removing Scripts"
		}
  ]
}