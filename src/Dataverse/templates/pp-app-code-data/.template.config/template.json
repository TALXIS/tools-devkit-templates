{
	"$schema": "http://json.schemastore.org/template",
	"author": "NETWORG",
	"identity": "TALXIS.DevKit.Templates.Dataverse.CodeApp.Data",
	"name": "Power Platform: Code App Data",
	"shortName": "pp-app-code-data",
	"description": "",
	"classifications": [
		"Dataverse",
		"Power Platform"
	],
	"sourceName": "pp-app-code-data",
	"tags": {
		"language": "XML",
		"type": "item"
	},
	"preferNameDirectory": true,
	"symbols": {
		"ModelSolutionPath": {
			"type": "parameter",
			"datatype": "text",
			"replaces": "modelsolutionexamplepath"
		},
		"EntityLogicalName": {
			"type": "parameter",
			"datatype": "text",
			"replaces": "entityexamplelogicalname",
			"description": "Logical name of the entity including publisher prefix (e.g., udpp_warehouseitem)"
		},
		"SolutionRootPath": {
			"type": "parameter",
			"datatype": "text",
			"defaultValue": ".",
			"replaces": "__solution-root-path__",
			"fileRename": "__solution-root-path__",
			"description": "Relative path from the project folder (.csproj) to the folder containing unpacked Dataverse solution files (Other/, Entities/, OptionSets/). Use '.' if solution files are directly in the project folder, or a subfolder name like 'Declarations'. Do not use 'Entities' or 'Other' — those are subdirectories inside the solution metadata root.",
			"isRequired": false
		}
	},
	"postActions": [
		{
			"actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
			"args": {
				"executable": "pwsh",
				"args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/Init.ps1\""
			},
			"description": "Init"
		},
		{
			"actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
			"args": {
				"executable": "pwsh",
				"args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/Cleanup.ps1\"",
				"redirectStandardOutput": "false"
			},
			"manualInstructions": [
				{
					"text": "Removing Scripts"
				}
			],
			"continueOnError": false,
			"description": "Removing Scripts"
		}
	]
}
