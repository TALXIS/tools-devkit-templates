{
  "$schema": "http://json.schemastore.org/template",
  "author": "NETWORG",
  "identity": "TALXIS.DevKit.Templates.Dataverse.Sitemap,Area",
  "name": "Power Platform: Site Map Area Group ",
  "shortName": "pp-sitemap-group",
  "description": "Adds <Group> to a sitemap area: Id, ResourceId, IsProfile=false, <Titles LCID=1033>. Organizes subareas. Add subareas with pp-sitemap-subarea.",
  "classifications": ["Dataverse", "Power Platform"],
  "sourceName": "Sitemap-Area-Group",
  "tags": {
		"type": "item",
		"language": "XML",
		"componentType": "SiteMap"
	},
  "preferNameDirectory": true,
  "symbols": {
    "SolutionRootPath": {
			"type": "parameter",
			"datatype": "text",
			"defaultValue": ".",
			"replaces": "__solution-root-path__",
			"fileRename": "__solution-root-path__",
			"description": "Relative path from the project folder (.csproj) to the folder containing unpacked Dataverse solution files (Other/, Entities/, OptionSets/). Use '.' if solution files are directly in the project folder, or a subfolder name like 'Declarations'. Do not use 'Entities' or 'Other' — those are subdirectories inside the solution metadata root."
		},
    "AppName": {
      "type": "parameter",
      "datatype": "text",
      "description": "Name of the app module including publisher prefix (e.g., udpp_warehouseapp)",
      "isRequired": true,
      "replaces": "appexamplename",
      "fileRename": "appexamplename"
    },
    "GroupDisplayName": {
      "type": "parameter",
      "datatype": "text",
      "description": "Display name of the group that will be created in the sitemap",
      "defaultValue": "New Group",
      "replaces": "groupdisplaynameexample",
      "fileRename": "groupdisplaynameexample"
    },
    "GroupTitle": {
      "type": "parameter",
      "datatype": "text",
      "description": "Title of the group that will be created in the sitemap",
      "defaultValue": "NewTitle",
      "replaces": "grouptitleexample",
      "fileRename": "grouptitleexample"
    },
    "AreaTitle": {
      "type": "parameter",
      "datatype": "text",
      "description": "Title of the area in the sitemap where the group will be added",
      "isRequired": true,
      "defaultValue": "NewTitle",
      "replaces": "areatitleexample",
      "fileRename": "areatitleexample"
    }
  },
  "sources": [
    {
      "modifiers": [
        {
          "include": ["**/*.xml"]
        }
      ]
    }
  ],
  "postActions": [
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/GenerateIdForAppModuleSiteMap.ps1\" "
      },
      "manualInstructions": [
        {
          "text": "Adding Model Driven App to solution xml"
        }
      ],
      "description": "Generate ID for app module site map"
    },
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/AddGroupToArea.ps1\""
      },
      "manualInstructions": [
        {
          "text": "Adding area to the sitemapp "
        }
      ],
      "description": "Add group to area"
    },
    {
			"actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
			"args": {
				"executable": "pwsh",
				"args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/Cleanup.ps1\"",
				"redirectStandardOutput": "false"
			},
			"manualInstructions": [{ "text": "Removing Scripts" }],
			"continueOnError": false,
			"description": "Removing Scripts"
		}
  ]
}