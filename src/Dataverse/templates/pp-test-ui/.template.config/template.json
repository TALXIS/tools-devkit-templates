{
  "$schema": "http://json.schemastore.org/template",
  "author": "NETWORG",
  "identity": "TALXIS.DevKit.Templates.Dataverse.Test.UI",
  "name": "Power Platform: UI Test",
  "shortName": "pp-test-ui",
  "description": "Creates a Reqnroll + Playwright UI test project for a Power Apps model-driven app.",
  "sourceName": "TestProjectName",
  "preferNameDirectory": true,
  "tags": {
    "type": "project",
    "language": "C#"
  },
  "primaryOutputs": [
    {
      "path": "TestProjectName.csproj"
    }
  ],
  "sources": [
    {
      "exclude": [
        "**/.git/**",
        "**/.vs/**",
        "**/[Bb]in/**",
        "**/[Oo]bj/**",
        "**/*.feature.cs",
        ".template.config/**/*"
      ]
    }
  ]
}
