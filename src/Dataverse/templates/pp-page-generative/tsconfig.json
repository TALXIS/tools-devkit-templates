{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "noEmitOnError": true
  },
  "include": ["*.ts", "*.tsx", "components/**/*.ts", "components/**/*.tsx", "styles/**/*.ts", "styles/**/*.tsx"]
}
