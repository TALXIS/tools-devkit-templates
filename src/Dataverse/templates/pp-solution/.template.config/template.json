{
  "$schema": "http://json.schemastore.org/template",
  "author": "NETWORG",
  "identity": "TALXIS.DevKit.Templates.Dataverse.Solution",
  "name": "Power Platform: Solution",
  "shortName": "pp-solution",
  "description": "Creates a Dataverse solution project: .csproj (TALXIS.DevKit.Build.Sdk, ProjectType=Solution, PublisherName, PublisherPrefix, Version=1.0.0.0). PAC CLI runs solution init as post-action. A repo typically has multiple solution projects with separate concerns (data model, logic, security, UI).",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "sourceName": "SolutionLogicalNameExample",
  "sources": [
    {
      "exclude": [
        "**/[Bb]in/**",
        "**/[Oo]bj/**",
        "*/**/[Bb]in/**",
        "*/**/[Oo]bj/**",
        "**/**/[Bb]in/**",
        "**/**/[Oo]bj/**",
        ".template.config/**/*"
      ]
    }
  ],
  "preferNameDirectory": true,
  "symbols": {
    "PublisherName": {
      "type": "parameter",
      "description": "Publisher name (company, product or team). Keep it short. Only characters within the ranges [A - Z], [a - z], [0 - 9], or _ are allowed. The first character may only be in the ranges [A - Z], [a - z], or _.",
      "datatype": "text",
      "replaces": "examplepublisher",
      "isRequired": true
    },
    "PublisherPrefix": {
      "type": "parameter",
      "description": "Keep it under 5 characters. Only characters within the ranges [a - z] and [0 - 9] are allowed. It is used by majority components in their unique system name.",
      "datatype": "text",
      "replaces": "examplepublisherprefix",
      "isRequired": true
    },
    "SolutionRootPath": {
			"type": "parameter",
			"datatype": "text",
			"defaultValue": ".",
			"replaces": "SolutionDeclarationsRoot",
			"fileRename": "SolutionDeclarationsRoot",
			"description": "Folder under the project folder where solution components will be placed. Use the folder name only, not the full path. Use '.' if you want to place components directly in the project folder."
		},
    "GeneratePluginAssembly": {
      "type": "parameter",
      "datatype": "choice",
      "isRequired": false,
      "replaces": "generateexamplepluginassembly",
      "defaultValue": "true",
      "choices": [
        {
          "choice": "true"
        },
        {
          "choice": "false"
        }
      ]
    }
  },
  "primaryOutputs": [
    {
      "path": "SolutionLogicalNameExample.csproj"
    }
  ],
  "postActions": [
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/FlattenSolutionRootIfInplace.ps1\"",
        "redirectStandardOutput": "false"
      },
      "manualInstructions": [
        {
          "text": "Flatten SolutionDeclarationsRoot if SolutionRootPath is '.'"
        }
      ],
      "continueOnError": false,
      "description": "Flatten SolutionDeclarationsRoot into project root when SolutionRootPath is '.'"
    },
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/EnsureSolutionInitialized.ps1\"",
        "redirectStandardOutput": "false"
      },
      "manualInstructions": [
        {
          "text": "Initialize a solution using PAC CLI"
        }
      ],
      "continueOnError": false,
      "description": "Initialize a solution using PAC CLI - pac solution init"
    },
    {
      "description": "Add generated project to .sln file",
      "manualInstructions": [
        {
          "text": "Add generated project to .sln file"
        }
      ],
      "args": {
        "inRoot": true
      },
      "actionId": "D396686C-DE0E-4DE6-906D-291CD29FC5DE",
      "continueOnError": false,
      "primaryOutputIndexes": "0"
    },
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/RemoveGeneratePluginAssemblyIfTrue.ps1\"",
        "redirectStandardOutput": "false"
      },
      "manualInstructions": [
        {
          "text": "Remove <GeneratePluginAssembly> from .csproj when value is true"
        }
      ],
      "continueOnError": false,
      "description": "Remove <GeneratePluginAssembly> from .csproj when GeneratePluginAssembly is true"
    },
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/Cleanup.ps1\"",
        "redirectStandardOutput": "false"
      },
      "manualInstructions": [
        {
          "text": "Removing template files"
        }
      ],
      "continueOnError": false,
      "description": "Removing template files"
    }
  ]
}
