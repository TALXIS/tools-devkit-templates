{
  "$schema": "http://json.schemastore.org/template",
  "author": "NETWORG",
  "identity": "TALXIS.DevKit.Templates.Dataverse.View",
  "name": "Power Platform: View",
  "shortName": "pp-entity-view",
  "description": "Adds a SavedQuery (view) XML for an existing entity. Includes fetchxml, grid layout, column definitions. queryType=64. Use when adding a new list view to an entity.",
  "tags": {
    "language": "XML",
    "type": "item"
  },
  "sourceName": "customentity",
  "preferNameDirectory": false,
  "symbols": {
    "SolutionRootPath": {
      "type": "parameter",
      "datatype": "text",
      "defaultValue": ".",
      "replaces": "__solution-root-path__",
      "fileRename": "__solution-root-path__",
      "description": "Relative path from the project folder (.csproj) to the folder containing unpacked Dataverse solution files (Other/, Entities/, OptionSets/). Use '.' if solution files are directly in the project folder, or a subfolder name like 'Declarations'. Do not use 'Entities' or 'Other' — those are subdirectories inside the solution metadata root."
    },
    "DisplayName": {
      "type": "parameter",
      "datatype": "text",
      "defaultValue": "Generated",
      "replaces": "viewexamplename",
      "description": "Display name of the view"
    },
    "EntitySchemaName": {
      "type": "parameter",
      "datatype": "text",
      "isRequired": true,
      "replaces": "exampleexistingentity",
      "fileRename": "exampleexistingentity",
      "description": "Schema name of the entity including publisher prefix (e.g., udpp_warehouseitem)"
    },
    "PublisherPrefix": {
      "type": "parameter",
      "datatype": "text",
      "isRequired": true,
      "replaces": "examplepublisherprefix",
      "fileRename": "examplepublisherprefix",
      "description": "Publisher prefix of the entity"
    },
    "ViewId": {
      "type": "generated",
      "generator": "guid",
      "replaces": "someexampleid",
      "fileRename": "someexampleid",
      "parameters": {
        "defaultFormat": "d"
      }
    }
  },
	"postActions": [
		{
			"actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
			"args": {
				"executable": "pwsh",
				"args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/SetFormId.ps1\"",
				"redirectStandardOutput": "false"
			},
			"manualInstructions": [
				{
					"text": "Setting view ID"
				}
			],
			"continueOnError": false,
			"description": "Setting view ID"
		},
		{
			"actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
			"args": {
				"executable": "pwsh",
				"args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/Cleanup.ps1\"",
				"redirectStandardOutput": "false"
			},
			"manualInstructions": [
				{
					"text": "Removing Scripts"
				}
			],
			"continueOnError": false,
			"description": "Removing Scripts"
		}
	]
}