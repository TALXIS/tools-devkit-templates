{
  "$schema": "http://json.schemastore.org/template",
  "author": "NETWORG",
  "identity": "TALXIS.DevKit.Templates.Dataverse.Flow",
  "name": "Power Platform: Cloud Flow",
  "shortName": "pp-flow",
  "description": "Scaffolds a Power Automate cloud flow: .json.data.xml metadata (Category=5 ModernFlow, Type=1) and .json flow definition with a manual trigger. Add connectors and actions in the flow designer.",
  "classifications": ["Dataverse", "Power Platform"],
  "tags": {
    "language": "JSON",
    "type": "item",
    "componentType": "Flow"
  },
  "preferNameDirectory": true,
  "sources": [
    {
      "exclude": [
        "**/[Bb]in/**",
        "**/[Oo]bj/**",
        ".template.config/**/*"
      ]
    }
  ],
  "symbols": {
    "SolutionRootPath": {
      "type": "parameter",
      "datatype": "text",
      "defaultValue": ".",
      "replaces": "__solution-root-path__",
      "fileRename": "__solution-root-path__",
      "isRequired": false,
      "description": "Relative path from the project folder (.csproj) to the folder containing unpacked Dataverse solution files (Other/, Entities/, OptionSets/). Use '.' if solution files are directly in the project folder, or a subfolder name like 'Declarations'. Do not use 'Entities' or 'Other' — those are subdirectories inside the solution metadata root."
    },
    "PublisherPrefix": {
      "type": "parameter",
      "datatype": "text",
      "replaces": "examplepublisher",
      "isRequired": true,
      "description": "Publisher prefix (e.g. contoso)"
    },
    "LogicalName": {
      "type": "parameter",
      "datatype": "text",
      "replaces": "examplelogicalname",
      "fileRename": "examplelogicalname",
      "isRequired": true,
      "description": "Logical name of the flow without publisher prefix (e.g. myautomation)"
    }
  },
  "postActions": [
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/GenerateFlowId.ps1\"",
        "redirectStandardOutput": "false"
      },
      "description": "Generate flow workflow ID and rename files"
    },
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/AddFlowToSolution.ps1\"",
        "redirectStandardOutput": "false"
      },
      "description": "Add flow to Solution.xml"
    },
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/Cleanup.ps1\"",
        "redirectStandardOutput": "false"
      },
      "manualInstructions": [{ "text": "Removing template scripts" }],
      "continueOnError": false,
      "description": "Removing template scripts"
    }
  ]
}
