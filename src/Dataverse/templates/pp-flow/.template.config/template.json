{
  "$schema": "http://json.schemastore.org/template",
  "author": "NETWORG",
  "identity": "TALXIS.DevKit.Templates.Dataverse.Flow",
  "name": "Power Platform: Cloud Flow",
  "shortName": "pp-flow",
  "description": "Scaffolds a Power Automate cloud flow: .json.data.xml metadata (Category=5 ModernFlow, Type=1) and .json flow definition with a manual trigger. Add connectors and actions in the flow designer.",
  "classifications": ["Dataverse", "Power Platform"],
  "tags": {
    "language": "JSON",
    "type": "item",
    "componentType": "Flow"
  },
  "preferNameDirectory": true,
  "sources": [
    {
      "exclude": [
        "**/[Bb]in/**",
        "**/[Oo]bj/**",
        ".template.config/**/*"
      ]
    }
  ],
  "symbols": {
    "PublisherPrefix": {
      "type": "parameter",
      "datatype": "text",
      "replaces": "__publisher-prefix__",
      "fileRename": "__publisher-prefix__",
      "isRequired": true,
      "description": "Publisher prefix (e.g. contoso)"
    },
    "LogicalName": {
      "type": "parameter",
      "datatype": "text",
      "replaces": "__logical-name__",
      "fileRename": "__logical-name__",
      "isRequired": true,
      "description": "Logical name of the flow without publisher prefix (e.g. myautomation)"
    },
    "FlowWorkflowId": {
      "type": "generated",
      "generator": "guid",
      "replaces": "__flow-workflow-id__",
      "parameters": {
        "defaultFormat": "d"
      }
    },
    "TriggerOperationId": {
      "type": "generated",
      "generator": "guid",
      "replaces": "__trigger-operation-id__",
      "parameters": {
        "defaultFormat": "d"
      }
    },
    "FlowWorkflowIdUpper": {
      "type": "generated",
      "generator": "casing",
      "parameters": {
        "source": "FlowWorkflowId",
        "toUpper": true
      },
      "replaces": "__flow-workflow-id-upper__",
      "fileRename": "__flow-workflow-id-upper__"
    }
  },
  "postActions": [
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/SetSolutionRootPath.ps1\""
      },
      "manualInstructions": [{ "text": "Set Solution Root Path" }],
      "continueOnError": false,
      "description": "Setting Solution Root Path"
    },
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/AddFlowToSolution.ps1\"",
        "redirectStandardOutput": "false"
      },
      "description": "Add flow to Solution.xml"
    },
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/Cleanup.ps1\"",
        "redirectStandardOutput": "false"
      },
      "manualInstructions": [{ "text": "Removing template scripts" }],
      "continueOnError": false,
      "description": "Removing template scripts"
    }
  ]
}
