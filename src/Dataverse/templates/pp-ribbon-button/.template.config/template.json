{
	"$schema": "http://json.schemastore.org/template",
	"author": "NETWORG",
	"identity": "TALXIS.DevKit.Templates.Dataverse.RibbonButton",
	"name": "Power Platform: Ribbon Button",
	"shortName": "pp-ribbon-button",
	"description": "Adds a ribbon button: commanddefinition.xml (JavaScriptFunction + $webresource ref) + customaction.xml (location, icons 16x32, sequence, TemplateAlias) + loclbels.xml (Alt, LabelText, ToolTipTitle, ToolTipDescription, LCID 1033). Injected into entity RibbonDiff.xml.",
	"tags": {
		"language": "XML",
		"type": "item",
		"componentType": "RibbonButton"
	},
	"sourceName": "examplebuttonname",
	"sources": [
		{
			"exclude": [
				"**/[Bb]in/**",
				"**/[Oo]bj/**",
				"*/**/[Bb]in/**",
				"*/**/[Oo]bj/**",
				"**/**/[Bb]in/**",
				"**/**/[Oo]bj/**",
				".template.config/**/*"
			]
		}
	],
	"preferNameDirectory": true,
	"symbols": {
		"PublisherPrefix": {
			"type": "parameter",
			"datatype": "text",
			"replaces": "__publisher-prefix__",
			"fileRename": "__publisher-prefix__",
			"isRequired": true,
			"description": "Publisher prefix for the ribbon button (Example: new, talxis)"
		},
		"ButtonLabel": {
			"type": "parameter",
			"datatype": "text",
			"replaces": "__button-label__",
			"fileRename": "__button-label__",
			"isRequired": true,
			"description": "Display label text for the ribbon button (e.g., Approve, Submit, Calculate)"
		},
		"EntityLogicalName": {
			"type": "parameter",
			"datatype": "text",
			"replaces": "__entity-logical-name__",
			"fileRename": "__entity-logical-name__",
			"isRequired": true,
			"description": "Logical name of the entity including publisher prefix (e.g., udpp_warehouseitem)"
		},
		"Image32by32": {
			"type": "parameter",
			"datatype": "text",
			"defaultValue": "icon32pathdefault",
			"replaces": "__image-32x32__",
			"fileRename": "__image-32x32__",
			"description": "Path to the 32x32 pixel icon image for the ribbon button"
		},
		"Image16by16": {
			"type": "parameter",
			"datatype": "text",
			"defaultValue": "icon16pathdefault",
			"replaces": "__image-16x16__",
			"fileRename": "__image-16x16__",
			"description": "Path to the 16x16 pixel icon image for the ribbon button"
		},
		"ModernImage": {
			"type": "parameter",
			"datatype": "text",
			"defaultValue": "modernimagedefault",
			"replaces": "__modern-image__",
			"fileRename": "__modern-image__",
			"description": "Optional. Web resource path for a modern SVG icon (e.g. 'myicon.svg' or 'subfolder/myicon.svg'). Rendered as ModernImage=\"$webresource:<value>\". Omitted from XML when not specified."
		},
		"Sequence": {
			"type": "parameter",
			"datatype": "text",
			"defaultValue": "10",
			"replaces": "__sequence__",
			"description": "Display order of the button within its location. Lower values appear first (PCT examples range from 1 to ~95). Default: 10."
		},
		"TemplateAlias": {
			"type": "parameter",
			"datatype": "text",
			"defaultValue": "o1",
			"replaces": "__template-alias__",
			"description": "Layout slot alias inside the ribbon template (Common values: o1, o2, o3, isv). Default: o1."
		},
		"Location": {
			"type": "parameter",
			"datatype": "choice",
			"description": "Select location of the button",
			"choices": [
				{
					"choice": "Home"
				},
				{
					"choice": "SubGrid"
				},
				{
					"choice": "Form"
				}
			]
		},
		"LocationPath": {
			"type": "generated",
			"generator": "switch",
			"replaces": "__location-path__",
			"parameters": {
				"datatype": "string",
				"cases": [
					{
						"condition": "(Location == 'Home')",
						"value": "HomepageGrid"
					},
					{
						"condition": "(Location == 'SubGrid')",
						"value": "SubGrid"
					},
					{
						"condition": "(Location == 'Form')",
						"value": "Form"
					}
				]
			}
		},
		"LibraryLogicalName": {
			"isRequired": true,
			"type": "parameter",
			"datatype": "text",
			"replaces": "__library-logical-name__",
			"fileRename": "__library-logical-name__",
			"description": "Logical name of the library where the ribbon button will be added"
		},
		"FunctionName": {
			"isRequired": true,
			"type": "parameter",
			"datatype": "text",
			"replaces": "__function-name__",
			"fileRename": "__function-name__",
			"description": "Logical name of the function where the ribbon button will be added"
		},
		"TabPath": {
			"type": "generated",
			"generator": "switch",
			"replaces": "__tab-path__",
			"parameters": {
				"datatype": "string",
				"cases": [
					{
						"condition": "(Location == 'Form')",
						"value": "MainTab.Save.Controls._children"
					},
					{
						"condition": "(Location == 'Home')",
						"value": "MainTab.Management.Controls._children"
					},
					{
						"condition": "(Location == 'SubGrid')",
						"value": "MainTab.Management.Controls._children"
					}
				]
			}
		}
	},
	"postActions": [
		{
			"actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
			"args": {
				"executable": "pwsh",
				"args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/SetSolutionRootPath.ps1\""
			},
			"manualInstructions": [{ "text": "Set Solution Root Path" }],
			"continueOnError": false,
			"description": "Setting Solution Root Path"
		},
		{
			"actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
			"args": {
				"executable": "pwsh",
				"args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/SetIcon.ps1\"",
				"redirectStandardOutput": "false"
			},
			"description": "Set icon"
		},
		{
			"actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
			"args": {
				"executable": "pwsh",
				"args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/SetButtonLogicalName.ps1\"",
				"redirectStandardOutput": "false"
			},
			"description": "Set button logical name"
		},
		{
			"actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
			"args": {
				"executable": "pwsh",
				"args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/RibbonDiff.ps1\"",
				"redirectStandardOutput": "false"
			},
			"description": "Ribbon diff"
		},
		{
			"actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
			"args": {
				"executable": "pwsh",
				"args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/Cleanup.ps1\"",
				"redirectStandardOutput": "false"
			},
			"description": "Cleanup"
		}
	]
}
