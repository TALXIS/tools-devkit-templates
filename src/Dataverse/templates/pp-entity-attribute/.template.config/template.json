{
  "$schema": "http://json.schemastore.org/template",
  "author": "NETWORG",
  "identity": "TALXIS.DevKit.Templates.Dataverse.Entity.Attribute",
  "name": "Power Platform: Entity Attribute",
  "shortName": "pp-entity-attribute",
  "description": "Adds a column to an existing entity. Types: Text, MultilineText, WholeNumber, Decimal, Float, Money, DateTime, Boolean, Lookup, Customer, File, Image, BigInt, OptionSet(Local/Global/LocalMulti/GlobalMulti).",
  "tags": {
    "language": "XML",
    "type": "item",
    "componentType": "Attribute"
  },
  "sourceName": "__attribute-logical-name__",
  "preferNameDirectory": false,
  "sources": [
		{
			"modifiers": [
				{
					"condition": "(!CreateGlobalOptionSet)",
					"exclude": ["__solution-root-path__/OptionSets/*"]
				}
			]
		}
	],
  "symbols": {
    "SolutionRootPath": {
      "type": "parameter",
      "datatype": "text",
      "defaultValue": ".",
      "replaces": "__solution-root-path__",
      "fileRename": "__solution-root-path__",
      "description": "Relative path from the project folder (.csproj) to the folder containing unpacked Dataverse solution files (Other/, Entities/, OptionSets/). Use '.' if solution files are directly in the project folder, or a subfolder name like 'Declarations'. Do not use 'Entities' or 'Other' — those are subdirectories inside the solution metadata root."
    },
    "CreateGlobalOptionSet": {
      "type": "computed",
      "value": "((AttributeType == \"OptionSet(Global)\") || (AttributeType == \"OptionSet(GlobalMulti)\")) && (OptionSetType == \"New\")",
      "description": "Automatically computed: True when AttributeType is New OptionSet(Global/GlobalMulti), False otherwise"
    },
    "EntitySchemaName": {
      "displayName": "Schema name of the entity including publisher prefix (might be different from logical name)",
      "type": "parameter",
      "datatype": "text",
      "fileRename": "__entity-schema-name__",
      "replaces": "__entity-schema-name__",
      "isRequired": true,
      "description": "Schema name of the entity including publisher prefix (e.g., udpp_warehouseitem)"
    },
    "AttributeType": {
      "type": "parameter",
      "description": "Data type of the column. Each type enables a specific set of type-prefixed parameters (e.g., Text enables TextFormat and TextMaxLength; Money enables MoneyAccuracySource, MoneyMinValue, MoneyMaxValue, and DecimalPrecision).",
      "datatype": "choice",
      "isRequired": true,
      "choices": [
        { "choice": "Text", "description": "Single line of text. Use TextFormat for email/url/phone/richtext variants. Use TextMaxLength for max characters." },
        { "choice": "MultilineText", "description": "Multiple lines of text (memo). Use MemoFormat for plain text or rich text. Use MemoMaxLength for max characters." },
        { "choice": "Autonumber", "description": "Auto-numbered text. Use AutonumberFormat with {SEQNUM:N}, {RANDSTRING:N}, {DATETIMEUTC:format} placeholders. Read-only in forms." },
        { "choice": "WholeNumber", "description": "Whole number (integer). Use WholeNumberFormat for standard/duration/timezone/language/locale variants." },
        { "choice": "Decimal", "description": "Decimal number. Use DecimalPrecision for decimal places, DecimalMinValue/DecimalMaxValue for range." },
        { "choice": "Float", "description": "Floating point number. Use DecimalPrecision for decimal places, DecimalMinValue/DecimalMaxValue for range." },
        { "choice": "Money", "description": "Currency field. Auto-creates _base support column. Use MoneyAccuracySource (0=attribute, 1=org, 2=currency), DecimalPrecision, MoneyMinValue/MoneyMaxValue." },
        { "choice": "DateTime", "description": "Date and time. Use DateTimeFormat (date/datetime) and DateTimeBehavior (1=UserLocal, 2=DateOnly, 3=TimeZoneIndependent)." },
        { "choice": "Boolean", "description": "Yes/No field. Use BooleanTrueLabel and BooleanFalseLabel to customize option labels." },
        { "choice": "Lookup", "description": "Lookup to another entity. Requires LookupTarget (e.g., account). Creates N:1 relationship." },
        { "choice": "Customer", "description": "Polymorphic lookup targeting Account and Contact. LookupTarget defaults to account." },
        { "choice": "OptionSet(Local)", "description": "Single-select choice scoped to this entity. Requires OptionSetOptions (e.g., Active:100000000,Inactive:100000001)." },
        { "choice": "OptionSet(Global)", "description": "Single-select choice shared across entities. Use OptionSetType=New to create or Existing to reference. Requires OptionSetOptions for New." },
        { "choice": "OptionSet(LocalMulti)", "description": "Multi-select choice scoped to this entity. Requires OptionSetOptions." },
        { "choice": "OptionSet(GlobalMulti)", "description": "Multi-select choice shared across entities. Use OptionSetType=New or Existing. Requires OptionSetOptions for New." },
        { "choice": "File", "description": "File attachment column. Use FileMaxSizeInKB for max size (default: 32 MB)." },
        { "choice": "Image", "description": "Image column. Use ImageMaxSizeInKB for max size (default: 10 MB)." },
        { "choice": "BigInt", "description": "64-bit integer for large numbers (timestamps, versioning)." },
        { "choice": "JsonText", "description": "JSON text column. Only valid on Elastic tables." }
      ]
    },
    "TextFormat": {
      "type": "parameter",
      "description": "[Text] Format for single-line text fields.",
      "datatype": "choice",
      "defaultValue": "text",
      "isEnabled": "(AttributeType == \"Text\")",
      "replaces": "__string-format__",
      "choices": [
        { "choice": "text", "description": "Plain text" },
        { "choice": "email", "description": "Email address" },
        { "choice": "url", "description": "URL" },
        { "choice": "phone", "description": "Phone number" },
        { "choice": "tickersymbol", "description": "Ticker symbol" },
        { "choice": "textarea", "description": "Text area" },
        { "choice": "richtext", "description": "Rich text with HTML editor" }
      ]
    },
    "MemoFormat": {
      "type": "parameter",
      "description": "[MultilineText] Format for multi-line text fields.",
      "datatype": "choice",
      "defaultValue": "text",
      "isEnabled": "(AttributeType == \"MultilineText\")",
      "replaces": "__memo-format__",
      "choices": [
        { "choice": "text", "description": "Plain text" },
        { "choice": "richtext", "description": "Rich text with HTML editor" }
      ]
    },
    "AutonumberFormat": {
      "type": "parameter",
      "description": "[Autonumber] Format string using {SEQNUM:N}, {RANDSTRING:N}, {DATETIMEUTC:format} placeholders (e.g., INV-{SEQNUM:5}-{DATETIMEUTC:yyyyMMdd}).",
      "datatype": "text",
      "defaultValue": "{SEQNUM:5}",
      "isEnabled": "(AttributeType == \"Autonumber\")",
      "replaces": "__autonumber-format__"
    },
    "WholeNumberFormat": {
      "type": "parameter",
      "description": "[WholeNumber] Format variant for integer fields.",
      "datatype": "choice",
      "defaultValue": "none",
      "isEnabled": "(AttributeType == \"WholeNumber\")",
      "replaces": "__number-format__",
      "choices": [
        { "choice": "none", "description": "Standard whole number" },
        { "choice": "duration", "description": "Duration (minutes)" },
        { "choice": "timezone", "description": "Time zone" },
        { "choice": "language", "description": "Language code" },
        { "choice": "locale", "description": "Locale" }
      ]
    },
    "DateTimeFormat": {
      "type": "parameter",
      "description": "[DateTime] Display format. Use 'date' for date picker only, 'datetime' for date+time. DateOnly behavior requires 'date'.",
      "datatype": "choice",
      "defaultValue": "date",
      "isEnabled": "(AttributeType == \"DateTime\")",
      "replaces": "__datetime-format__",
      "choices": [
        { "choice": "date", "description": "Date only (date picker)" },
        { "choice": "datetime", "description": "Date and time (date + time picker)" }
      ]
    },
    "DateTimeBehavior": {
      "type": "parameter",
      "description": "[DateTime] Time zone behavior. Controls how values are stored and displayed across time zones.",
      "datatype": "choice",
      "defaultValue": "1",
      "isEnabled": "(AttributeType == \"DateTime\")",
      "replaces": "__datetime-behavior__",
      "choices": [
        { "choice": "1", "description": "User local (stores as UTC, converts to user TZ)" },
        { "choice": "2", "description": "Date only (no time component)" },
        { "choice": "3", "description": "Time zone independent (stores actual value)" }
      ]
    },
    "BooleanTrueLabel": {
      "type": "parameter",
      "description": "[Boolean] Label for the true/yes option.",
      "datatype": "text",
      "defaultValue": "Yes",
      "isEnabled": "(AttributeType == \"Boolean\")",
      "replaces": "__boolean-true-label__"
    },
    "BooleanFalseLabel": {
      "type": "parameter",
      "description": "[Boolean] Label for the false/no option.",
      "datatype": "text",
      "defaultValue": "No",
      "isEnabled": "(AttributeType == \"Boolean\")",
      "replaces": "__boolean-false-label__"
    },
    "OptionSetType": {
      "type": "parameter",
      "description": "[OptionSet(Global/GlobalMulti)] Whether to create a new global option set or reference an existing one.",
      "datatype": "choice",
      "isEnabled": "(AttributeType == \"OptionSet(Global)\") || (AttributeType == \"OptionSet(GlobalMulti)\")",
      "isRequired": "(AttributeType == \"OptionSet(Global)\") || (AttributeType == \"OptionSet(GlobalMulti)\")",
      "choices": [
        { "choice": "New", "description": "Create a new global option set with the options specified in OptionSetOptions" },
        { "choice": "Existing", "description": "Reference an existing global option set by name (specify OptionSetName)" }
      ]
    },
    "OptionSetName": {
      "type": "parameter",
      "description": "[OptionSet(Global/GlobalMulti)] Logical name of the global option set. Required for Existing; defaults to attribute schema name for New.",
      "datatype": "text",
      "defaultValue": "",
      "isEnabled": "(AttributeType == \"OptionSet(Global)\") || (AttributeType == \"OptionSet(GlobalMulti)\")",
      "replaces": "__global-optionset-name-override__"
    },
    "OptionSetNameIsOverridden": {
      "type": "computed",
      "value": "(OptionSetName != \"\")"
    },
    "RequiredLevel": {
      "type": "parameter",
      "description": "Select required level",
      "datatype": "choice",
      "replaces": "__required-level__",
      "choices": [
        { "choice": "none" },
        { "choice": "recommended" },
        { "choice": "required" }
      ],
      "defaultValue": "none"
    },
    "PublisherPrefix": {
      "type": "parameter",
      "description": "Use the same publisher prefix as defined in Other/Solution.xml of the solution where this attribute is introduced to the system.",
      "datatype": "text",
      "isRequired": true
    },
    "LogicalName": {
      "displayName": "Logical name (without publisher prefix)",
      "description": "Logical name of the attribute without publisher prefix (e.g., availablequantity). The prefix is added automatically.",
      "type": "parameter",
      "datatype": "text",
      "replaces": "__attribute-logical-name__",
      "isRequired": true
    },
    "AttributeSchemaNameUnsanitized": {
      "type": "generated",
      "generator": "join",
      "parameters": {
        "symbols": [
          { "type": "ref", "value": "PublisherPrefix" },
          { "type": "ref", "value": "LogicalName" }
        ],
        "separator": "_",
        "removeEmptyValues": true
      }
    },
    "AttributeSchemaName": {
      "type": "generated",
      "generator": "casing",
      "parameters": {
        "source": "AttributeSchemaNameUnsanitized",
        "toLower": true
      },
      "replaces": "__attribute-schema-name__",
      "fileRename": "__attribute-schema-name__",
      "description": "Final attribute schema/logical name including publisher prefix"
    },
    "DisplayName": {
      "type": "parameter",
      "datatype": "text",
      "replaces": "__attribute-display-name__",
      "isRequired": true,
      "description": "Display name for the attribute that will be shown to users"
    },
    "OptionSetOptions": {
      "type": "parameter",
      "datatype": "text",
      "replaces": "__option-set-options__",
      "description": "[OptionSet(Local/Global/LocalMulti/GlobalMulti)] Options for the choice column. Comma-separated labels (e.g., Active,Inactive) or Label:Value pairs (e.g., Active:100000000,Inactive:100000001). Values auto-increment from 100000000 if omitted.",
      "isEnabled": "(AttributeType == \"OptionSet(Local)\" || AttributeType == \"OptionSet(LocalMulti)\" || AttributeType == \"OptionSet(Global)\" || AttributeType == \"OptionSet(GlobalMulti)\")",
      "isRequired": "(AttributeType == \"OptionSet(Local)\" || AttributeType == \"OptionSet(LocalMulti)\" || ((AttributeType == \"OptionSet(Global)\" || AttributeType == \"OptionSet(GlobalMulti)\") && OptionSetType == \"New\"))"
    },
    "Description": {
      "type": "parameter",
      "datatype": "text",
      "replaces": "__attribute-description__",
      "defaultValue": "",
      "description": "Description of the attribute that explains its purpose"
    },
    "TextMaxLength": {
      "type": "parameter",
      "datatype": "int",
      "defaultValue": 100,
      "replaces": "__max-length__",
      "isEnabled": "(AttributeType == \"Text\" || AttributeType == \"Autonumber\")",
      "description": "[Text] Maximum character length for single-line text (default: 100)."
    },
    "MemoMaxLength": {
      "type": "parameter",
      "datatype": "int",
      "defaultValue": 2000,
      "replaces": "__max-length-memo__",
      "isEnabled": "(AttributeType == \"MultilineText\")",
      "description": "[MultilineText] Maximum character length for multi-line/memo text (default: 2000)."
    },
    "DecimalPrecision": {
      "type": "parameter",
      "datatype": "int",
      "defaultValue": 2,
      "replaces": "__precision__",
      "isEnabled": "(AttributeType == \"Decimal\" || AttributeType == \"Float\" || AttributeType == \"Money\")",
      "description": "[Decimal/Float/Money] Number of decimal places (default: 2)."
    },
    "DecimalMinValue": {
      "type": "parameter",
      "datatype": "text",
      "defaultValue": "-100000000000",
      "replaces": "__min-value__",
      "isEnabled": "(AttributeType == \"Decimal\" || AttributeType == \"Float\")",
      "description": "[Decimal/Float] Minimum allowed value. Decimal default: -100000000000; Float default: 0."
    },
    "DecimalMaxValue": {
      "type": "parameter",
      "datatype": "text",
      "defaultValue": "100000000000",
      "replaces": "__max-value__",
      "isEnabled": "(AttributeType == \"Decimal\" || AttributeType == \"Float\")",
      "description": "[Decimal/Float] Maximum allowed value. Decimal default: 100000000000; Float default: 1000000000."
    },
    "MoneyMinValue": {
      "type": "parameter",
      "datatype": "text",
      "defaultValue": "-922337203685477",
      "replaces": "__min-value-money__",
      "isEnabled": "(AttributeType == \"Money\")",
      "description": "[Money] Minimum allowed value (default: -922337203685477)."
    },
    "MoneyMaxValue": {
      "type": "parameter",
      "datatype": "text",
      "defaultValue": "922337203685477",
      "replaces": "__max-value-money__",
      "isEnabled": "(AttributeType == \"Money\")",
      "description": "[Money] Maximum allowed value (default: 922337203685477)."
    },
    "MoneyAccuracySource": {
      "type": "parameter",
      "description": "[Money] Precision source: 0=use attribute Precision value, 1=use organization pricing precision, 2=use currency precision.",
      "datatype": "choice",
      "defaultValue": "2",
      "isEnabled": "(AttributeType == \"Money\")",
      "replaces": "__accuracy-source__",
      "choices": [
        { "choice": "0", "description": "Attribute precision (use DecimalPrecision value)" },
        { "choice": "1", "description": "Organization pricing precision" },
        { "choice": "2", "description": "Currency precision (default)" }
      ]
    },
    "WholeNumberMinValue": {
      "type": "parameter",
      "datatype": "text",
      "defaultValue": "-2147483648",
      "replaces": "__min-value-int__",
      "isEnabled": "(AttributeType == \"WholeNumber\")",
      "description": "[WholeNumber] Minimum allowed value (default: -2147483648)."
    },
    "WholeNumberMaxValue": {
      "type": "parameter",
      "datatype": "text",
      "defaultValue": "2147483647",
      "replaces": "__max-value-int__",
      "isEnabled": "(AttributeType == \"WholeNumber\")",
      "description": "[WholeNumber] Maximum allowed value (default: 2147483647)."
    },
    "FileMaxSizeInKB": {
      "type": "parameter",
      "datatype": "int",
      "defaultValue": 32768,
      "replaces": "__max-file-size__",
      "isEnabled": "(AttributeType == \"File\")",
      "description": "[File] Maximum file size in KB (default: 32768 = 32 MB)."
    },
    "ImageMaxSizeInKB": {
      "type": "parameter",
      "datatype": "int",
      "defaultValue": 10240,
      "replaces": "__max-image-size__",
      "isEnabled": "(AttributeType == \"Image\")",
      "description": "[Image] Maximum image size in KB (default: 10240 = 10 MB)."
    },

    "LookupTarget": {
      "type": "parameter",
      "datatype": "text",
      "defaultValue": "account",
      "replaces": "__referenced-entity-name__",
      "isEnabled": "(AttributeType == \"Lookup\") || (AttributeType == \"Customer\")",
      "isRequired": "(AttributeType == \"Lookup\")",
      "description": "[Lookup/Customer] Logical name of the target entity (e.g., udpp_warehouseitem). Required for Lookup; defaults to account for Customer."
    },
    "AddLookupRelationship": {
      "type": "computed",
      "value": "(AttributeType == \"Lookup\") || (AttributeType == \"Customer\")",
      "datatype": "bool",
      "description": "Automatically computed: True when AttributeType is Lookup or Customer, False otherwise"
    },
    "LookupRelationshipNameUnsanitized": {
      "type": "generated",
      "generator": "join",
      "parameters": {
        "symbols": [
          { "type": "ref", "value": "PublisherPrefix" },
          { "type": "ref", "value": "LookupTarget" },
          { "type": "ref", "value": "EntitySchemaName" },
          { "type": "ref", "value": "LogicalName" }
        ],
        "separator": "_",
        "removeEmptyValues": true
      },
      "description": "Generated relationship name combining publisher prefix, referenced entity, entity schema, and attribute logical name"
    },
    "LookupRelationshipName": {
      "type": "generated",
      "generator": "casing",
      "parameters": {
        "source": "LookupRelationshipNameUnsanitized",
        "toLower": true
      },
      "replaces": "__lookup-relationship-name__",
      "description": "Final lookup relationship name converted to lowercase (automatically generated)"
    }
  },
  "postActions": [
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "condition": "(AttributeType == \"OptionSet(Local)\" || AttributeType == \"OptionSet(LocalMulti)\" || ((AttributeType == \"OptionSet(Global)\" || AttributeType == \"OptionSet(GlobalMulti)\") && (OptionSetType == \"New\")))",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/SetOptionSetOptions.ps1\"",
        "redirectStandardOutput": "false"
      },
      "manualInstructions": [
        { "text": "Setting option set options" }
      ],
      "continueOnError": false,
      "description": "Setting option set options"
    },
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/AddAttributeToEntityXml.ps1\"",
        "redirectStandardOutput": "false"
      },
      "manualInstructions": [
        { "text": "Adding attribute to entity.xml" }
      ],
      "continueOnError": false,
      "description": "Adding attribute to entity.xml"
    },
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "condition": "(AttributeType == \"Money\")",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/AddMoneySupportToEntityXml.ps1\"",
        "redirectStandardOutput": "false"
      },
      "manualInstructions": [
        { "text": "Adding money support attributes to entity.xml" }
      ],
      "continueOnError": false,
      "description": "Adding money support attributes to entity.xml"
    },
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "condition": "(AddLookupRelationship)",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/AddLookupRelationship.ps1\"",
        "redirectStandardOutput": "false"
      },
      "manualInstructions": [
        { "text": "Adding lookup relationship xml" }
      ],
      "continueOnError": false,
      "description": "Adding lookup relationship xml"
    },
    
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/SortEntityAttributes.ps1\"",
        "redirectStandardOutput": "false"
      },
      "manualInstructions": [
        { "text": "Sorting entity attributes alphabetically by PhysicalName" }
      ],
      "continueOnError": false,
      "description": "Sorting entity attributes"
    },
    {
      "actionId": "7D61D1F8-0E07-4CB7-9D51-84B9F04E3F6A",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/NormalizeNilTags.ps1\"",
        "redirectStandardOutput": false,
        "redirectStandardError": false
      },
      "manualInstructions": [
        { "text": "Normalizing xsi:nil tags in solution.xml" }
      ],
      "continueOnError": true,
      "description": "Normalizing xsi:nil tags in solution.xml"
    },
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/Cleanup.ps1\"",
        "redirectStandardOutput": "false"
      },
      "manualInstructions": [
        { "text": "Removing Scripts" }
      ],
      "continueOnError": false,
      "description": "Removing Scripts"
    }
  ]
}
