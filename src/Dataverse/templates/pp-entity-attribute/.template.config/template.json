{
  "$schema": "http://json.schemastore.org/template",
  "author": "NETWORG",
  "identity": "TALXIS.DevKit.Templates.Dataverse.Entity.Attribute",
  "name": "Power Platform: Entity Attribute",
  "shortName": "pp-entity-attribute",
  "description": "Adds a column to an existing entity. Types: Text, MultilineText, WholeNumber, Decimal, Float, Money, DateTime, Boolean, Lookup, Customer, File, Image, BigInt, OptionSet(Local/Global/LocalMulti/GlobalMulti). Generates attribute.xml + LookupRelationship.xml (for Lookup/Customer) + optionset XML (for new Global OptionSet). Required: EntitySchemaName, PublisherPrefix, LogicalName, DisplayName.",
  "tags": {
    "language": "XML",
    "type": "item"
  },
  "sourceName": "__attribute-logical-name__",
  "preferNameDirectory": false,
  "sources": [
		{
			"modifiers": [
				{
					"condition": "(!CreateGlobalOptionSet)",
					"exclude": ["__solution-root-path__/OptionSets/*"]
				}
			]
		}
	],
  "symbols": {
    "SolutionRootPath": {
      "type": "parameter",
      "datatype": "text",
      "defaultValue": ".",
      "replaces": "__solution-root-path__",
      "fileRename": "__solution-root-path__",
      "description": "Folder under the project folder where solution components will be placed. Use the folder name only, not the full path. Use '.' if you want to place components directly in the project folder."
    },
    "CreateGlobalOptionSet": {
      "type": "computed",
      "value": "((AttributeType == \"OptionSet(Global)\") || (AttributeType == \"OptionSet(GlobalMulti)\")) && (GlobalOptionSetType == \"New\")",
      "description": "Automatically computed: True when AttributeType is New OptionSet(Global/GlobalMulti), False otherwise"
    },
    "EntitySchemaName": {
      "displayName": "Schema name of the entity including publisher prefix (might be different from logical name)",
      "type": "parameter",
      "datatype": "text",
      "fileRename": "__entity-schema-name__",
      "replaces": "__entity-schema-name__",
      "isRequired": true,
      "description": "Schema name of the entity including publisher prefix (e.g., udpp_warehouseitem)"
    },
    "AttributeType": {
      "type": "parameter",
      "description": "Data type of the attribute",
      "datatype": "choice",
      "isRequired": true,
      "choices": [
        { "choice": "Text", "description": "Single line of text (nvarchar)" },
        { "choice": "MultilineText", "description": "Multiple lines of text (ntext/memo)" },
        { "choice": "WholeNumber", "description": "Whole number (int)" },
        { "choice": "Decimal", "description": "Decimal number" },
        { "choice": "Float", "description": "Floating point number" },
        { "choice": "Money", "description": "Currency with base field and support columns" },
        { "choice": "DateTime", "description": "Date and time" },
        { "choice": "Boolean", "description": "Yes/No (bit)" },
        { "choice": "Lookup", "description": "Lookup to another entity" },
        { "choice": "Customer", "description": "Customer lookup (Account/Contact)" },
        { "choice": "OptionSet(Local)", "description": "Local choice (single select)" },
        { "choice": "OptionSet(Global)", "description": "Global choice (single select)" },
        { "choice": "OptionSet(LocalMulti)", "description": "Local choice (multi select)" },
        { "choice": "OptionSet(GlobalMulti)", "description": "Global choice (multi select)" },
        { "choice": "File", "description": "File attachment" },
        { "choice": "Image", "description": "Image" },
        { "choice": "BigInt", "description": "Big integer" },
        { "choice": "JsonText", "description": "Only for Elastic tables" }
      ]
    },
    "StringFormat": {
      "type": "parameter",
      "description": "Format for single-line text fields",
      "datatype": "choice",
      "defaultValue": "text",
      "replaces": "__string-format__",
      "choices": [
        { "choice": "text", "description": "Plain text" },
        { "choice": "email", "description": "Email address" },
        { "choice": "url", "description": "URL" },
        { "choice": "phone", "description": "Phone number" },
        { "choice": "tickersymbol", "description": "Ticker symbol" },
        { "choice": "textarea", "description": "Text area" }
      ]
    },
    "NumberFormat": {
      "type": "parameter",
      "description": "Format for whole number fields",
      "datatype": "choice",
      "defaultValue": "none",
      "replaces": "__number-format__",
      "choices": [
        { "choice": "none", "description": "Standard whole number" },
        { "choice": "duration", "description": "Duration (minutes)" },
        { "choice": "timezone", "description": "Time zone" },
        { "choice": "language", "description": "Language code" },
        { "choice": "locale", "description": "Locale" }
      ]
    },
    "DateTimeBehaviorChoice": {
      "type": "parameter",
      "description": "Date/time behavior: 0=User local (date and time), 1=Date only, 2=Time zone independent (date and time)",
      "datatype": "choice",
      "defaultValue": "0",
      "replaces": "__datetime-behavior__",
      "choices": [
        { "choice": "0", "description": "User local (date and time)" },
        { "choice": "1", "description": "Date only" },
        { "choice": "2", "description": "Time zone independent (date and time)" }
      ]
    },
    "BooleanTrueLabel": {
      "type": "parameter",
      "description": "Label for the true/yes option on Boolean fields",
      "datatype": "text",
      "defaultValue": "Yes",
      "replaces": "__boolean-true-label__"
    },
    "BooleanFalseLabel": {
      "type": "parameter",
      "description": "Label for the false/no option on Boolean fields",
      "datatype": "text",
      "defaultValue": "No",
      "replaces": "__boolean-false-label__"
    },
    "GlobalOptionSetType": {
      "type": "parameter",
      "description": "Whether to create a new global option set or reference an existing one",
      "datatype": "choice",
      "isRequired": "(AttributeType == \"OptionSet(Global)\") || (AttributeType == \"OptionSet(GlobalMulti)\")",
      "choices": [
        { "choice": "New" },
        { "choice": "Existing" }
      ]
    },
    "GlobalOptionSetName": {
      "type": "parameter",
      "description": "Logical name of the global option set. Defaults to the attribute schema name if not specified.",
      "datatype": "text",
      "defaultValue": "",
      "replaces": "__global-optionset-name-override__"
    },
    "RequiredLevel": {
      "type": "parameter",
      "description": "Select required level",
      "datatype": "choice",
      "replaces": "__required-level__",
      "choices": [
        { "choice": "none" },
        { "choice": "recommended" },
        { "choice": "required" }
      ],
      "defaultValue": "none"
    },
    "PublisherPrefix": {
      "type": "parameter",
      "description": "Use the same publisher prefix as defined in Other/Solution.xml of the solution where this attribute is introduced to the system.",
      "datatype": "text",
      "isRequired": true
    },
    "LogicalName": {
      "displayName": "Logical name (without publisher prefix)",
      "description": "Logical name of the attribute without publisher prefix (e.g., availablequantity). The prefix is added automatically.",
      "type": "parameter",
      "datatype": "text",
      "replaces": "__attribute-logical-name__",
      "isRequired": true
    },
    "AttributeSchemaNameUnsanitized": {
      "type": "generated",
      "generator": "join",
      "parameters": {
        "symbols": [
          { "type": "ref", "value": "PublisherPrefix" },
          { "type": "ref", "value": "LogicalName" }
        ],
        "separator": "_",
        "removeEmptyValues": true
      }
    },
    "AttributeSchemaName": {
      "type": "generated",
      "generator": "casing",
      "parameters": {
        "source": "AttributeSchemaNameUnsanitized",
        "toLower": true
      },
      "replaces": "__attribute-schema-name__",
      "fileRename": "__attribute-schema-name__",
      "description": "Final attribute schema/logical name including publisher prefix"
    },
    "DisplayName": {
      "type": "parameter",
      "datatype": "text",
      "replaces": "__attribute-display-name__",
      "isRequired": true,
      "description": "Display name for the attribute that will be shown to users"
    },
    "OptionSetOptions": {
      "type": "parameter",
      "datatype": "text",
      "replaces": "__option-set-options__",
      "description": "Options for the option set. Comma-separated labels (e.g., Active,Inactive) or Label:Value pairs (e.g., Active:100000000,Inactive:100000001). If values are omitted, they auto-increment from 100000000.",
      "isRequired": "(AttributeType == \"OptionSet(Local)\" || AttributeType == \"OptionSet(LocalMulti)\" || ((AttributeType == \"OptionSet(Global)\" || AttributeType == \"OptionSet(GlobalMulti)\") && GlobalOptionSetType == \"New\"))"
    },
    "Description": {
      "type": "parameter",
      "datatype": "text",
      "replaces": "__attribute-description__",
      "defaultValue": "",
      "description": "Description of the attribute that explains its purpose"
    },
    "MaxLength": {
      "type": "parameter",
      "datatype": "int",
      "defaultValue": 100,
      "replaces": "__max-length__",
      "isRequired": "false",
      "description": "Maximum length for single-line text attributes (default: 100)"
    },
    "MaxLengthMemo": {
      "type": "parameter",
      "datatype": "int",
      "defaultValue": 2000,
      "replaces": "__max-length-memo__",
      "isRequired": "false",
      "description": "Maximum length for multi-line text attributes (default: 2000)"
    },
    "Precision": {
      "type": "parameter",
      "datatype": "int",
      "defaultValue": 2,
      "replaces": "__precision__",
      "isRequired": "false",
      "description": "Number of decimal places for decimal/float/money attributes (default: 2)"
    },
    "MinValue": {
      "type": "parameter",
      "datatype": "text",
      "defaultValue": "-100000000000",
      "replaces": "__min-value__",
      "isRequired": "false",
      "description": "Minimum value for decimal/float attributes (default: -100000000000)"
    },
    "MaxValue": {
      "type": "parameter",
      "datatype": "text",
      "defaultValue": "100000000000",
      "replaces": "__max-value__",
      "isRequired": "false",
      "description": "Maximum value for decimal/float attributes (default: 100000000000)"
    },
    "MinValueMoney": {
      "type": "parameter",
      "datatype": "text",
      "defaultValue": "-922337203685477",
      "replaces": "__min-value-money__",
      "isRequired": "false",
      "description": "Minimum value for money attributes (default: -922337203685477)"
    },
    "MaxValueMoney": {
      "type": "parameter",
      "datatype": "text",
      "defaultValue": "922337203685477",
      "replaces": "__max-value-money__",
      "isRequired": "false",
      "description": "Maximum value for money attributes (default: 922337203685477)"
    },
    "MinValueInt": {
      "type": "parameter",
      "datatype": "text",
      "defaultValue": "-2147483648",
      "replaces": "__min-value-int__",
      "isRequired": "false",
      "description": "Minimum value for whole number attributes"
    },
    "MaxValueInt": {
      "type": "parameter",
      "datatype": "text",
      "defaultValue": "2147483647",
      "replaces": "__max-value-int__",
      "isRequired": "false",
      "description": "Maximum value for whole number attributes"
    },
    "MaxFileSizeInKB": {
      "type": "parameter",
      "datatype": "int",
      "defaultValue": 32768,
      "replaces": "__max-file-size__",
      "isRequired": "false",
      "description": "Maximum file size in KB for File attributes (default: 32768 = 32 MB)"
    },
    "MaxImageSizeInKB": {
      "type": "parameter",
      "datatype": "int",
      "defaultValue": 10240,
      "replaces": "__max-image-size__",
      "isRequired": "false",
      "description": "Maximum image size in KB for Image attributes (default: 10240 = 10 MB)"
    },
    "CanStoreFullImage": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "true",
      "replaces": "__can-store-full-image__",
      "isRequired": "false",
      "description": "Whether full-size images can be stored (default: true)"
    },
    "ReferencedEntityName": {
      "type": "parameter",
      "datatype": "text",
      "replaces": "__referenced-entity-name__",
      "isRequired": "(AttributeType == \"Lookup\") || (AttributeType == \"Customer\")",
      "description": "Logical name of the referenced entity including publisher prefix (e.g., udpp_warehouseitem). For Customer type, defaults to account."
    },
    "AddLookupRelationship": {
      "type": "computed",
      "value": "(AttributeType == \"Lookup\") || (AttributeType == \"Customer\")",
      "datatype": "bool",
      "description": "Automatically computed: True when AttributeType is Lookup or Customer, False otherwise"
    },
    "LookupRelationshipNameUnsanitized": {
      "type": "generated",
      "generator": "join",
      "parameters": {
        "symbols": [
          { "type": "ref", "value": "PublisherPrefix" },
          { "type": "ref", "value": "ReferencedEntityName" },
          { "type": "ref", "value": "EntitySchemaName" },
          { "type": "ref", "value": "LogicalName" }
        ],
        "separator": "_",
        "removeEmptyValues": true
      },
      "description": "Generated relationship name combining publisher prefix, referenced entity, entity schema, and attribute logical name"
    },
    "LookupRelationshipName": {
      "type": "generated",
      "generator": "casing",
      "parameters": {
        "source": "LookupRelationshipNameUnsanitized",
        "toLower": true
      },
      "replaces": "__lookup-relationship-name__",
      "description": "Final lookup relationship name converted to lowercase (automatically generated)"
    }
  },
  "postActions": [
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "condition": "(AttributeType == \"OptionSet(Local)\" || AttributeType == \"OptionSet(LocalMulti)\" || ((AttributeType == \"OptionSet(Global)\" || AttributeType == \"OptionSet(GlobalMulti)\") && (GlobalOptionSetType == \"New\")))",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/SetOptionSetOptions.ps1\"",
        "redirectStandardOutput": "false"
      },
      "manualInstructions": [
        { "text": "Setting option set options" }
      ],
      "continueOnError": false,
      "description": "Setting option set options"
    },
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/AddAttributeToEntityXml.ps1\"",
        "redirectStandardOutput": "false"
      },
      "manualInstructions": [
        { "text": "Adding attribute to entity.xml" }
      ],
      "continueOnError": false,
      "description": "Adding attribute to entity.xml"
    },
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "condition": "(AttributeType == \"Money\")",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/AddMoneySupportToEntityXml.ps1\"",
        "redirectStandardOutput": "false"
      },
      "manualInstructions": [
        { "text": "Adding money support attributes to entity.xml" }
      ],
      "continueOnError": false,
      "description": "Adding money support attributes to entity.xml"
    },
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "condition": "(AddLookupRelationship)",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/AddLookupRelationship.ps1\"",
        "redirectStandardOutput": "false"
      },
      "manualInstructions": [
        { "text": "Adding lookup relationship xml" }
      ],
      "continueOnError": false,
      "description": "Adding lookup relationship xml"
    },
    
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/SortEntityAttributes.ps1\"",
        "redirectStandardOutput": "false"
      },
      "manualInstructions": [
        { "text": "Sorting entity attributes alphabetically by PhysicalName" }
      ],
      "continueOnError": false,
      "description": "Sorting entity attributes"
    },
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/Cleanup.ps1\"",
        "redirectStandardOutput": "false"
      },
      "manualInstructions": [
        { "text": "Removing Scripts" }
      ],
      "continueOnError": false,
      "description": "Removing Scripts"
    }
  ]
}
