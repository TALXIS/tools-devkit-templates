{
	"$schema": "http://json.schemastore.org/template",
	"author": "NETWORG",
	"identity": "TALXIS.DevKit.Templates.Dataverse.RibbonCommandParameter",
	"name": "Power Platform: Ribbon Command Parameter",
	"shortName": "pp-ribbon-command-parameter",
	"description": "Adds a parameter to a ribbon command. Types: CrmParameter(SelectedControl), CrmParameter(PrimaryControl), StringParameter. Injected into command definition in RibbonDiff.xml.",
	"tags": {
		"language": "XML",
		"type": "item",
		"componentType": "RibbonCommandParameter"
	},
	"sourceName": "examplebuttonname",
	"sources": [
		{
			"exclude": [
				"**/[Bb]in/**",
				"**/[Oo]bj/**",
				"*/**/[Bb]in/**",
				"*/**/[Oo]bj/**",
				"**/**/[Bb]in/**",
				"**/**/[Oo]bj/**",
				".template.config/**/*"
			]
		}
	],
	"preferNameDirectory": true,
	"symbols": {
		"PublisherPrefix": {
			"type": "parameter",
			"datatype": "text",
			"replaces": "__publisher-prefix__",
			"fileRename": "__publisher-prefix__",
			"isRequired": true,
			"description": "Publisher prefix for the ribbon button (Example: new, talxis)"
		},
		"EntityLogicalName": {
			"type": "parameter",
			"datatype": "text",
			"replaces": "__entity-logical-name__",
			"fileRename": "__entity-logical-name__",
			"isRequired": true,
			"description": "Logical name of the entity including publisher prefix (e.g., udpp_warehouseitem)"
		},
		"ParameterInput": {
			"type": "parameter",
			"datatype": "text",
			"replaces": "__parameter-input__",
			"fileRename": "__parameter-input__",
			"isRequired": "ParameterType == \"String\"",
			"description": ""
		},
		"ParameterType": {
			"type": "parameter",
			"datatype": "choice",
			"isRequired": true,
			"choices": [
				{
					"choice": "CrmSelectedControl"
				},
				{
					"choice": "String"
				},
				{
					"choice": "CrmPrimaryControl"
				}
			],
			"description": "Type of parameter: Crm Selected Control (SelectedControl), String (String), Crm Primary Control (PrimaryControl)"
		},
		"FunctionName": {
			"isRequired": true,
			"type": "parameter",
			"datatype": "text",
			"replaces": "__function-name__",
			"fileRename": "__function-name__",
			"description": "Logical name of the function where the ribbon button will be added"
		},
		"ButtonLogicalName": {
			"type": "parameter",
			"datatype": "text",
			"replaces": "__button-logical-name__",
			"isRequired": true,
			"description": "Logical name of the button (lowercase, no spaces/punctuation — same as generated by pp-ribbon-button from the ButtonLabel). Used to find the CommandDefinition in RibbonDiff.xml."
		}
	},
	"postActions": [
		{
			"actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
			"args": {
				"executable": "pwsh",
				"args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/SetSolutionRootPath.ps1\""
			},
			"manualInstructions": [{ "text": "Set Solution Root Path" }],
			"continueOnError": false,
			"description": "Setting Solution Root Path"
		},
		{
			"actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
			"args": {
				"executable": "pwsh",
				"args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/SetParameter.ps1\"",
				"redirectStandardOutput": "false"
			},
			"description": "Set parameter"
		},
		{
			"actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
			"args": {
				"executable": "pwsh",
				"args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/Cleanup.ps1\"",
				"redirectStandardOutput": "false"
			},
			"description": "Cleanup"
		}
	]
}
